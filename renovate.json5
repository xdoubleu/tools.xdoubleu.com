{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^\\.github/workflows/.*\\.yml$/',
      ],
      matchStrings: [
        '# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)\\n\\s+version: (?<currentValue>v[^\\s]+)',
      ],
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/Makefile$/',
      ],
      matchStrings: [
        'go install (?<depName>[^@]+)@(?<currentValue>[0-9a-zA-Z.]+)',
      ],
      datasourceTemplate: 'go',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^go.mod$/',
      ],
      matchStrings: [
        '\\sgo (?<currentValue>.+?)\\s',
      ],
      depNameTemplate: 'golang',
      datasourceTemplate: 'docker',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/buf\\.gen\\.yaml$/',
      ],
      matchStrings: [
        '# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)\\n\\s+- remote: [^:]+:(?<currentValue>v[^\\s]+)',
      ],
    },
  ],
  packageRules: [
    {
      groupName: 'golangci-lint',
      matchDepNames: [
        'github.com/golangci/golangci-lint/v2/cmd/golangci-lint',
        'golangci/golangci-lint',
      ],
    },
    {
      groupName: 'proto',
      matchDepNames: [
        '@bufbuild/protobuf',
        '@bufbuild/protoc-gen-es',
        'bufbuild/protobuf-es',
      ],
    },
    {
      groupName: 'proto',
      matchDepNames: [
        '@connectrpc/connect',
        '@connectrpc/connect-web',
      ],
    },
    {
      groupName: 'proto',
      matchDepNames: [
        'google.golang.org/protobuf',
        'protocolbuffers/protobuf-go',
      ],
    },
    {
      groupName: 'proto',
      matchDepNames: [
        'connectrpc.com/connect',
        'connectrpc/connect-go',
      ],
    },
  ],
  timezone: 'Europe/Brussels',
  labels: [
    'dependencies',
  ],
  dependencyDashboardLabels: [
    'dependencies',
  ],
  schedule: [
    'monthly',
  ],
  automerge: true,
  automergeType: 'pr',
  platformAutomerge: true,
}
